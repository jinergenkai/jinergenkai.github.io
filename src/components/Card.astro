---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
  featured?: boolean;
} & CollectionEntry<"thoughts">;

const {
  variant: Heading = "h2",
  featured = false,
  id,
  data,
  filePath,
  ...attrs
} = Astro.props;

const { title, description, lang = "vi", ogImage, ...props } = data;
---

<li
  {...attrs}
  class:list={[
    "card-glow group/card relative my-3 rounded-2xl overflow-hidden",
    "border border-border/25",
    "transition-all duration-300 ease-out",
    "hover:border-accent/40 hover:bg-accent/5",
    "hover:-translate-y-0.5",
    "hover:shadow-lg hover:shadow-accent/10",
    featured &&
      "border-accent/40 bg-accent/5 shadow-[0_0_20px_-5px_rgba(var(--accent),0.15)]",
  ]}
>
  <!-- Cover image strip (top, separated from text) -->
  {ogImage && (
    <div class="card-img-strip" aria-hidden="true">
      <img src={ogImage} alt="" class="card-img" />
      <div class="card-img-fade"></div>
    </div>
  )}
  <!-- Cursor-following glow -->
  <div
    class="card-glow-effect pointer-events-none absolute inset-0 z-0 rounded-2xl opacity-0 transition-opacity duration-300 group-hover/card:opacity-100"
    aria-hidden="true"
  >
  </div>
  <!-- Noise dithering -->
  <div
    class="card-noise pointer-events-none absolute inset-0 z-1 rounded-2xl opacity-0 transition-opacity duration-300 group-hover/card:opacity-100"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-5 p-4 sm:p-5">
    <a
      href={getPath(id, filePath)}
      class="rounded-sm text-lg font-semibold text-foreground transition-colors duration-200 group-hover/card:text-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-background focus-visible:outline-none"
      style={{
        viewTransitionName: slugifyStr(String(title).replaceAll(".", "-")),
      }}
    >
      <Heading>
        {title}
      </Heading>
      <!-- Expand clickable area to whole card on top of everything, minus the description -->
      <span class="absolute inset-0 z-10" aria-hidden="true"></span>
    </a>

    <div
      class="pointer-events-none relative z-20 mt-1.5 flex items-center gap-2"
    >
      <Datetime
        pubDatetime={props.pubDatetime as string | Date}
        modDatetime={props.modDatetime as string | Date | null | undefined}
      />
      <span
        class="lang-badge"
        aria-label={lang === "en" ? "English" : "Tiếng Việt"}
      >
        {lang === "en" ? "🇬🇧 EN" : "🇻🇳 VI"}
      </span>
    </div>

    <p
      class="pointer-events-auto relative z-20 mt-2 line-clamp-2 text-sm leading-relaxed opacity-65 select-text"
    >
      {description}
    </p>
  </div>
</li>

<style>
  /* Image strip at top */
  .card-img-strip {
    position: relative;
    width: 100%;
    height: 140px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }
  .group\/card:hover .card-img {
    transform: scale(1.04);
  }
  /* Fade strip into card background at bottom */
  .card-img-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(to bottom, transparent, var(--background));
    pointer-events: none;
  }

  .card-glow-effect {
    background: radial-gradient(
      350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      color-mix(in oklab, var(--accent) 8%, transparent) 0%,
      color-mix(in oklab, var(--accent) 6%, transparent) 15%,
      color-mix(in oklab, var(--accent) 4%, transparent) 30%,
      color-mix(in oklab, var(--accent) 2%, transparent) 45%,
      color-mix(in oklab, var(--accent) 0.8%, transparent) 60%,
      transparent 80%
    );
    transform: translateZ(0);
    will-change: transform;
  }
  .card-noise {
    background-image: url("/noise.png");
    background-repeat: repeat;
    background-size: 64px 64px;
    mix-blend-mode: overlay;
    opacity: 0;
  }
  .group\/card:hover .card-noise {
    opacity: 0.4;
  }

  .lang-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-family: var(--font-cartograph, monospace);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    background: color-mix(in srgb, var(--muted) 20%, transparent);
    color: var(--muted-foreground);
    opacity: 0.7;
    user-select: none;
  }
</style>
