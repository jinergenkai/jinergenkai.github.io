---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("thoughts", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: 100 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`Thoughts | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-4 mt-8">
    <!-- Filter bar -->
    <div class="filter-bar" id="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Priority</span>
        <button class="filter-btn active" data-audience="all">Latest</button>
        <button class="filter-btn" data-audience="tech">Tech</button>
        <button class="filter-btn" data-audience="business">Business</button>
        <button class="filter-btn" data-audience="life">Life</button>
        <button class="filter-btn" data-audience="learning">Learning</button>
      </div>
    </div>

    <!-- Posts Grid -->
    <div class="w-full">
      {
        page.data.length === 0 ? (
          <div class="empty-state">
            <h3 class="empty-title">No thoughts yet</h3>
            <p class="empty-desc">Come back later.</p>
          </div>
        ) : (
          <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="thoughts-grid">
            {page.data.map((post: any) => (
              <Card
                {...post}
                data-audience={JSON.stringify(post.data.audience ?? ["tech"])}
              />
            ))}
          </ul>
        )
      }
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Soft sort: hides nothing, just floats the prioritized audience group to the top
  // (each group keeps its chronological order). "Latest" = pure time-based sort.
  function initSort() {
    const params = new URLSearchParams(window.location.search);
    let active = params.get("audience") || "all";

    const items = document.querySelectorAll<HTMLElement>("#thoughts-grid [data-audience]");
    const btns = document.querySelectorAll<HTMLButtonElement>("#filter-bar [data-audience]");

    function apply() {
      items.forEach(item => {
        const audiences: string[] = JSON.parse(item.dataset.audience || '["tech"]');
        const prioritized = active !== "all" && audiences.includes(active);
        // order 0 = prioritized (keeps source order = time), order 1 = the rest
        item.style.order = active === "all" || prioritized ? "0" : "1";
        item.classList.toggle("deprioritized", active !== "all" && !prioritized);
      });

      const p = new URLSearchParams();
      if (active !== "all") p.set("audience", active);
      window.history.replaceState({}, "", p.toString() ? `?${p}` : window.location.pathname);
    }

    btns.forEach(btn => {
      const val = btn.dataset.audience!;
      btn.classList.toggle("active", val === active);
      btn.addEventListener("click", () => {
        active = val;
        btns.forEach(b => b.classList.toggle("active", b.dataset.audience === active));
        apply();
      });
    });

    apply();
  }

  document.addEventListener("astro:page-load", initSort);
</script>

<style>
  /* Filter bar */
  .filter-bar {
    display: flex; flex-wrap: wrap; gap: 1rem;
    margin-bottom: 2rem; align-items: center;
  }
  .filter-group { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  @media (max-width: 639px) {
    .filter-bar { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; padding-bottom: 4px; }
    .filter-bar::-webkit-scrollbar { display: none; }
    .filter-group { flex-shrink: 0; flex-wrap: nowrap; }
  }
  .filter-label {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em;
    opacity: 0.4; text-transform: uppercase; margin-right: 0.2rem;
  }
  .filter-btn {
    padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.78rem;
    border: 1px solid color-mix(in srgb, var(--border) 30%, transparent);
    background: transparent; color: var(--foreground); opacity: 0.6;
    cursor: pointer; transition: all 0.2s ease;
  }
  .filter-btn:hover { opacity: 1; border-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  .filter-btn.active {
    opacity: 1; color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  /* Posts outside the prioritized group: dim slightly, restore on hover */
  #thoughts-grid > .deprioritized {
    opacity: 0.55;
    transition: opacity 0.25s ease;
  }
  #thoughts-grid > .deprioritized:hover { opacity: 1; }

  /* General empty state */
  .empty-state {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 4rem 2rem; text-align: center; border-radius: 1.5rem;
    border: 2px dashed color-mix(in srgb, var(--border) 40%, transparent);
  }
  .empty-title { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
  .empty-desc { font-size: 0.95rem; color: var(--muted-foreground); }
</style>
