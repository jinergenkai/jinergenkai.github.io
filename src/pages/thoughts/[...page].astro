---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("thoughts", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: 100 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const totalPosts = page.total;
---

<Layout title={`Thoughts | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-4">
    <!-- Hero -->
    <div class="posts-hero" data-posts-hero>
      <div class="aurora-orb aurora-orb-1"></div>
      <div class="aurora-orb aurora-orb-2"></div>
      <div class="aurora-orb aurora-orb-3"></div>
      <div class="aurora-mouse" data-posts-mouse></div>
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          <span class="glow-text">Thoughts</span>
        </h1>
        <p class="mt-3 max-w-lg text-foreground/70 italic">
          Suy nghĩ về tech, business, cuộc sống và những thứ đang học.
        </p>
        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="hero-badge" id="visible-count">{totalPosts} thoughts</span>
        </div>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar" id="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Audience</span>
        <button class="filter-btn active" data-audience="all">All</button>
        <button class="filter-btn" data-audience="tech">Tech</button>
        <button class="filter-btn" data-audience="business">Business</button>
        <button class="filter-btn" data-audience="life">Life</button>
        <button class="filter-btn" data-audience="learning">Learning</button>
      </div>
    </div>

    <!-- Posts Grid -->
    <div class="w-full">
      {
        page.data.length === 0 ? (
          <div class="empty-state">
            <h3 class="empty-title">No thoughts yet</h3>
            <p class="empty-desc">Come back later.</p>
          </div>
        ) : (
          <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="thoughts-grid">
            {page.data.map((post: any) => (
              <Card
                {...post}
                data-audience={JSON.stringify(post.data.audience ?? ["tech"])}
              />
            ))}
          </ul>
          <p class="empty-filter-msg" id="empty-filter-msg" style="display:none">
            No thoughts match the current filter.
          </p>
        )
      }
    </div>
  </main>

  <Footer />
</Layout>

<script>
  function initFilters() {
    const params = new URLSearchParams(window.location.search);
    let activeAudience = params.get("audience") || "all";

    const items = document.querySelectorAll<HTMLElement>("#thoughts-grid [data-audience]");
    const emptyMsg = document.getElementById("empty-filter-msg");
    const countBadge = document.getElementById("visible-count");
    const audienceBtns = document.querySelectorAll<HTMLButtonElement>("#filter-bar [data-audience]");

    function applyFilter() {
      let visible = 0;
      items.forEach(item => {
        const audiences: string[] = JSON.parse(item.dataset.audience || '["tech"]');
        const show = activeAudience === "all" || audiences.includes(activeAudience);
        item.style.display = show ? "" : "none";
        if (show) visible++;
      });

      if (countBadge) countBadge.textContent = `${visible} thoughts`;
      if (emptyMsg) emptyMsg.style.display = visible === 0 ? "" : "none";

      const p = new URLSearchParams();
      if (activeAudience !== "all") p.set("audience", activeAudience);
      window.history.replaceState({}, "", p.toString() ? `?${p}` : window.location.pathname);
    }

    function bindGroup(
      btns: NodeListOf<HTMLButtonElement>,
      attr: string,
      getter: () => string,
      setter: (v: string) => void
    ) {
      btns.forEach(btn => {
        const val = (btn.dataset as any)[attr];
        btn.classList.toggle("active", val === getter());
        btn.addEventListener("click", () => {
          setter(val);
          btns.forEach(b => b.classList.toggle("active", (b.dataset as any)[attr] === val));
          applyFilter();
        });
      });
    }

    bindGroup(audienceBtns, "audience", () => activeAudience, v => (activeAudience = v));
    applyFilter();
  }

  document.addEventListener("astro:page-load", initFilters);
</script>

<style>
  .posts-hero {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    padding: 2.5rem 2rem;
    margin-bottom: 2rem;
    background: color-mix(in srgb, var(--color-foreground) 3%, var(--color-background));
    border: 1px solid color-mix(in srgb, var(--color-accent) 12%, transparent);
  }
  @media (min-width: 640px) { .posts-hero { padding: 3rem; } }

  .aurora-orb {
    position: absolute; border-radius: 50%; filter: blur(60px);
    pointer-events: none; will-change: transform;
  }
  .aurora-orb-1 {
    width: 300px; height: 300px; top: -30%; left: -10%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 25%, transparent), transparent 70%);
    animation: orb-1 7s ease-in-out infinite alternate;
  }
  .aurora-orb-2 {
    width: 250px; height: 250px; top: 10%; right: -5%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-border) 20%, transparent), transparent 70%);
    animation: orb-2 9s ease-in-out infinite alternate;
  }
  .aurora-orb-3 {
    width: 200px; height: 200px; bottom: -20%; left: 40%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 70%);
    animation: orb-3 11s ease-in-out infinite alternate;
  }
  @keyframes orb-1 { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(40px,20px) scale(1.2); } }
  @keyframes orb-2 { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(-30px,30px) scale(1.15); } }
  @keyframes orb-3 { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(20px,-25px) scale(1.1); } }

  .aurora-mouse {
    position: absolute; width: 350px; height: 350px; border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 18%, transparent), color-mix(in srgb, var(--color-border) 8%, transparent) 40%, transparent 70%);
    filter: blur(50px); pointer-events: none; opacity: 0; transition: opacity 0.4s ease;
    transform: translate(calc(var(--mx, 0px) - 175px), calc(var(--my, 0px) - 175px));
    will-change: transform; z-index: 1;
  }

  .glow-text {
    background: linear-gradient(135deg, var(--color-foreground), var(--color-accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    filter: drop-shadow(0 0 25px color-mix(in srgb, var(--color-accent) 25%, transparent));
  }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.3rem 0.85rem; border-radius: 999px;
    font-size: 0.8rem; font-weight: 600; color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    backdrop-filter: blur(8px);
  }

  /* Filter bar */
  .filter-bar {
    display: flex; flex-wrap: wrap; gap: 1rem;
    margin-bottom: 2rem; align-items: center;
  }
  .filter-group { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  @media (max-width: 639px) {
    .filter-bar { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; padding-bottom: 4px; }
    .filter-bar::-webkit-scrollbar { display: none; }
    .filter-group { flex-shrink: 0; flex-wrap: nowrap; }
  }
  .filter-label {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em;
    opacity: 0.4; text-transform: uppercase; margin-right: 0.2rem;
  }
  .filter-btn {
    padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.78rem;
    border: 1px solid color-mix(in srgb, var(--border) 30%, transparent);
    background: transparent; color: var(--foreground); opacity: 0.6;
    cursor: pointer; transition: all 0.2s ease;
  }
  .filter-btn:hover { opacity: 1; border-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  .filter-btn.active {
    opacity: 1; color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  /* Empty state for filters */
  .empty-filter-msg {
    text-align: center; padding: 3rem; opacity: 0.5; font-style: italic;
  }

  /* General empty state */
  .empty-state {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 4rem 2rem; text-align: center; border-radius: 1.5rem;
    border: 2px dashed color-mix(in srgb, var(--border) 40%, transparent);
  }
  .empty-title { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
  .empty-desc { font-size: 0.95rem; color: var(--muted-foreground); }
</style>
