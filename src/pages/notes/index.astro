---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Datetime from "@/components/Datetime.astro";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

const allNotes = await getCollection("notes", ({ data }) => !data.draft);
const sorted = allNotes.sort(
  (a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime()
);

const subjectLabel: Record<string, string> = {
  gmat: "GMAT", english: "English", java: "Java", other: "Other",
};
---

<Layout title={`Notes | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12 mt-8">
    <!-- Filters -->
    <div class="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Subject</span>
        <button class="filter-btn active" data-subject="all">All</button>
        <button class="filter-btn" data-subject="gmat">GMAT</button>
        <button class="filter-btn" data-subject="english">English</button>
        <button class="filter-btn" data-subject="java">Java</button>
        <button class="filter-btn" data-subject="other">Other</button>
      </div>
    </div>

    <!-- Notes list -->
    <ul class="notes-list" id="notes-list">
      {sorted.map(note => (
        <li class="note-card" data-lang={note.data.lang} data-subject={note.data.subject}>
          <a href={`/notes/${note.id}/`} class="note-link">
            <div class="note-meta">
              <span class="subject-badge">{subjectLabel[note.data.subject]}</span>
              <Datetime pubDatetime={note.data.pubDatetime} size="sm" class="opacity-60" />
              <span class="lang-pill">{note.data.lang === "en" ? "🇬🇧 EN" : "🇻🇳 VI"}</span>
            </div>
            <h2 class="note-title" style={{ viewTransitionName: slugifyStr(note.data.title.replaceAll(".", "-")) }}>{note.data.title}</h2>
            <p class="note-desc">{note.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</Layout>

<script>
  function initFilters() {
    const params = new URLSearchParams(window.location.search);
    let activeSubject = params.get("subject") || "all";

    const items = document.querySelectorAll<HTMLElement>(".note-card");

    function applyFilter() {
      items.forEach(item => {
        const ok = activeSubject === "all" || item.dataset.subject === activeSubject;
        item.style.display = ok ? "" : "none";
      });
      const p = new URLSearchParams();
      if (activeSubject !== "all") p.set("subject", activeSubject);
      window.history.replaceState({}, "", p.toString() ? `?${p}` : window.location.pathname);
    }

    function bindGroup(attr: string, getter: () => string, setter: (v: string) => void) {
      document.querySelectorAll<HTMLButtonElement>(`[data-${attr}]`).forEach(btn => {
        const val = btn.dataset[attr]!;
        btn.classList.toggle("active", val === getter());
        btn.addEventListener("click", () => {
          setter(val);
          document.querySelectorAll<HTMLButtonElement>(`[data-${attr}]`).forEach(b =>
            b.classList.toggle("active", b.dataset[attr] === val)
          );
          applyFilter();
        });
      });
    }

    bindGroup("subject", () => activeSubject, v => (activeSubject = v));
    applyFilter();
  }

  document.addEventListener("astro:page-load", initFilters);
</script>

<style>
  .filter-bar { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; align-items: center; }
  .filter-group { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  @media (max-width: 639px) {
    .filter-bar { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; padding-bottom: 4px; }
    .filter-bar::-webkit-scrollbar { display: none; }
    .filter-group { flex-shrink: 0; flex-wrap: nowrap; }
  }
  .filter-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; opacity: 0.4; text-transform: uppercase; margin-right: 0.2rem; }
  .filter-btn {
    padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.78rem;
    border: 1px solid color-mix(in srgb, var(--border) 30%, transparent);
    background: transparent; color: var(--foreground); opacity: 0.6; cursor: pointer; transition: all 0.2s ease;
  }
  .filter-btn:hover { opacity: 1; border-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  .filter-btn.active { opacity: 1; color: var(--accent); border-color: color-mix(in srgb, var(--accent) 40%, transparent); background: color-mix(in srgb, var(--accent) 8%, transparent); }

  .notes-list { display: flex; flex-direction: column; gap: 1rem; list-style: none; padding: 0; margin: 0; }
  .note-card { border-radius: 1rem; border: 1px solid color-mix(in srgb, var(--border) 20%, transparent); transition: all 0.25s ease; }
  .note-card:hover { border-color: color-mix(in srgb, var(--accent) 30%, transparent); background: color-mix(in srgb, var(--accent) 3%, transparent); transform: translateY(-1px); }
  .note-link { display: block; padding: 1.25rem 1.5rem; text-decoration: none; }
  .note-meta { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .subject-badge {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    padding: 0.1rem 0.5rem; border-radius: 999px;
  }
  .lang-pill { font-size: 0.65rem; font-weight: 600; padding: 0.1rem 0.4rem; border-radius: 999px; border: 1px solid color-mix(in srgb, var(--border) 40%, transparent); opacity: 0.6; }
  .note-title { font-size: 1.1rem; font-weight: 600; color: var(--foreground); margin-bottom: 0.35rem; transition: color 0.2s; }
  .note-card:hover .note-title { color: var(--accent); }
  .note-desc { font-size: 0.875rem; opacity: 0.6; line-height: 1.6; }
</style>
