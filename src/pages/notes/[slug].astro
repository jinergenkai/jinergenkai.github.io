---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Datetime from "@/components/Datetime.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import SubscribeForm from "@/components/SubscribeForm.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => !data.draft);
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { title, description, pubDatetime, lang, subject, difficulty, tags } = note.data;
const { Content, headings } = await render(note);

const subjectLabel: Record<string, string> = {
  gmat: "GMAT", english: "English", java: "Java", other: "Other",
};
const h2s = headings.filter(h => h.depth === 2);
---

<Layout title={`${title} | Notes | ${SITE.title}`} description={description}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12" data-pagefind-body>
    <div class="notes-layout">
      <!-- Sticky TOC sidebar -->
      {h2s.length > 0 && (
        <aside class="toc-sidebar" id="toc">
          <div class="toc-inner">
            <p class="toc-heading">Contents</p>
            <nav>
              <ul class="toc-list">
                {h2s.map(h => (
                  <li>
                    <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- Main content -->
      <div class="note-main">
        <header class="note-header">
          <div class="note-header-top">
            <div class="note-meta">
              <span class="subject-badge">{subjectLabel[subject]}</span>
              <span class={`diff-badge diff-${difficulty}`}>{difficulty}</span>
              <Datetime {pubDatetime} size="sm" class="opacity-60" />
              <span class="lang-pill">{lang === "en" ? "🇬🇧 EN" : "🇻🇳 VI"}</span>
            </div>
            <button class="copy-link-btn" id="copy-link-btn" aria-label="Copy link" type="button">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <span id="copy-label">Copy link</span>
            </button>
          </div>
          <h1 class="note-title" transition:name={slugifyStr(title.replaceAll(".", "-"))}>{title}</h1>
          {description && <p class="note-desc">{description}</p>}
          {tags.length > 0 && (
            <div class="note-tags">
              {tags.map(t => <a href={`/tags/${t}/`} class="tag">#{t}</a>)}
            </div>
          )}
          <div class="notice-bar">
            📖 These notes are shared for learning purposes
          </div>
        </header>

        <article class="note-content app-prose prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)">
          <Content />
        </article>

        <SubscribeForm />

        <div class="mt-8 mb-4">
          <ShareLinks />
        </div>

        <div class="note-back">
          <a href="/notes" class="back-link">← Back to Notes</a>
        </div>
      </div>
    </div>
  </main>
  <BackToTopButton />
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className = "progress-container fixed top-0 z-50 h-1 w-full bg-background";
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";
    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const myBar = document.getElementById("myBar");
      if (myBar) myBar.style.width = scrolled + "%";
    });
  }
  updateScrollProgress();

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>

<script>
  function initTOC() {
    const links = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
    if (!links.length) return;
    const headings = Array.from(links)
      .map(l => document.getElementById(l.getAttribute("href")!.slice(1)))
      .filter(Boolean) as HTMLElement[];

    function setActive(index: number) {
      links.forEach(l => l.classList.remove("active"));
      if (index >= 0) links[index].classList.add("active");
    }

    function onScroll() {
      const nearBottom =
        window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 80;
      if (nearBottom) { setActive(headings.length - 1); return; }

      let active = -1;
      for (let i = 0; i < headings.length; i++) {
        if (headings[i].getBoundingClientRect().top <= 120) active = i;
      }
      setActive(active);
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  function initCopyLink() {
    const btn = document.getElementById("copy-link-btn");
    const label = document.getElementById("copy-label");
    if (!btn || !label) return;
    btn.addEventListener("click", async () => {
      await navigator.clipboard.writeText(window.location.href);
      label.textContent = "Copied!";
      btn.classList.add("copied");
      setTimeout(() => {
        label.textContent = "Copy link";
        btn.classList.remove("copied");
      }, 2000);
    });
  }

  function addHeadingLinks() {
    const headings = Array.from(document.querySelectorAll(".note-content h2, .note-content h3, .note-content h4, .note-content h5, .note-content h6"));
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className = "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + (heading as HTMLElement).id;
      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      link.ariaLabel = "link to heading";
      heading.appendChild(link);
    }
  }

  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll(".note-content pre"));
    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset = computedStyle.getPropertyValue("--file-name-offset").trim() !== "";
      const topClass = hasFileNameOffset ? "top-(--file-name-offset)" : "-top-3";
      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);
      copyButton.addEventListener("click", async () => {
        const code = codeBlock.querySelector("code");
        const text = code?.innerText;
        await navigator.clipboard.writeText(text ?? "");
        copyButton.innerText = "Copied";
        setTimeout(() => { copyButton.innerText = copyButtonLabel; }, 700);
      });
    }
  }

  document.addEventListener("astro:page-load", () => { initTOC(); initCopyLink(); addHeadingLinks(); attachCopyButtons(); });
</script>

<style>
  .notes-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .notes-layout {
      grid-template-columns: 220px 1fr;
    }
  }

  /* TOC Sidebar */
  .toc-sidebar {
    display: none;
  }
  @media (min-width: 1024px) {
    .toc-sidebar {
      display: block;
      position: sticky;
      top: 5rem;
    }
  }
  .toc-inner {
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--border) 20%, transparent);
    background: color-mix(in srgb, var(--foreground) 2%, var(--background));
    padding: 1.25rem;
  }
  .toc-heading {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; opacity: 0.4; margin-bottom: 0.75rem;
  }
  .toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.1rem; }
  .toc-link {
    display: block; padding: 0.3rem 0.5rem; border-radius: 0.375rem;
    font-size: 0.8rem; color: var(--foreground); opacity: 0.6;
    text-decoration: none; transition: all 0.15s ease;
    border-left: 2px solid transparent;
  }
  .toc-link:hover { opacity: 1; border-left-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  .toc-link.active { opacity: 1; color: var(--accent); border-left-color: var(--accent); background: color-mix(in srgb, var(--accent) 5%, transparent); }

  /* Note header */
  .note-header {
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--border) 20%, transparent);
    background: color-mix(in srgb, var(--foreground) 2%, var(--background));
    padding: 1.75rem; margin-bottom: 1.5rem;
  }
  .note-meta { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .subject-badge {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    padding: 0.1rem 0.5rem; border-radius: 999px;
  }
  .diff-badge {
    font-size: 0.65rem; font-weight: 600; padding: 0.1rem 0.45rem;
    border-radius: 999px; border: 1px solid; text-transform: capitalize;
  }
  .diff-beginner { color: #16a34a; border-color: #16a34a40; background: #16a34a10; }
  .diff-intermediate { color: #b45309; border-color: #b4530940; background: #b4530910; }
  .diff-advanced { color: #dc2626; border-color: #dc262640; background: #dc262610; }
  html[data-theme="dark"] .diff-beginner { color: #4ade80; border-color: #4ade8040; background: #4ade8010; }
  html[data-theme="dark"] .diff-intermediate { color: #fbbf24; border-color: #fbbf2440; background: #fbbf2410; }
  html[data-theme="dark"] .diff-advanced { color: #f87171; border-color: #f8717140; background: #f8717110; }
  .lang-pill { font-size: 0.65rem; font-weight: 600; padding: 0.1rem 0.4rem; border-radius: 999px; border: 1px solid color-mix(in srgb, var(--border) 40%, transparent); opacity: 0.6; }
  .note-title { font-size: 1.75rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.5rem; }
  .note-desc { font-size: 0.9rem; opacity: 0.6; font-style: italic; margin-bottom: 0.75rem; }
  .note-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .tag { font-size: 0.72rem; opacity: 0.5; text-decoration: none; color: var(--foreground); transition: opacity 0.2s; }
  .tag:hover { opacity: 1; color: var(--accent); }
  .notice-bar {
    margin-top: 0.75rem; padding: 0.5rem 0.75rem; border-radius: 0.5rem;
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 15%, transparent);
    font-size: 0.78rem; opacity: 0.7; font-style: italic;
  }

  .note-content { margin-bottom: 1.5rem; }
  .note-back { margin-top: 2rem; }
  .back-link { font-size: 0.85rem; color: var(--accent); opacity: 0.7; text-decoration: none; transition: opacity 0.2s; }
  .back-link:hover { opacity: 1; }

  /* Copy link */
  .note-header-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 1rem; margin-bottom: 0.75rem;
  }
  .copy-link-btn {
    display: inline-flex; align-items: center; gap: 0.35rem; flex-shrink: 0;
    padding: 0.3rem 0.7rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
    color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    cursor: pointer; transition: all 0.2s ease;
  }
  .copy-link-btn:hover { background: color-mix(in srgb, var(--accent) 12%, transparent); }
  .copy-link-btn.copied { color: #4ade80; border-color: #4ade8040; background: #4ade8010; }
</style>
