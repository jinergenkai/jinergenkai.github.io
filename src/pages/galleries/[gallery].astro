---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Datetime from "@/components/Datetime.astro";
import { SITE } from "@/config";

export async function getStaticPaths() {
  if (!SITE.showGalleries) return [];
  const galleries = await getCollection("galleries", ({ data }) => !data.draft);
  return galleries.map(g => ({
    params: {
      gallery: g.id
        .replace(/\/index\.(md|mdx)$/, "")
        .replace(/\.(md|mdx)$/, ""),
    },
    props: { entry: g },
  }));
}

const { entry } = Astro.props;
const { title, description, pubDatetime, coverImage, galleryType, lang, tags, audioUrl, source } = entry.data;
const { Content } = await render(entry);

const typeLabel: Record<string, string> = {
  poem: "Thơ", quote: "Quote", photo: "Photo", fun: "Fun",
};

const isLucBat = tags.some(t => t === "luc-bat");
---

<Layout title={`${title} | Galleries | ${SITE.title}`} description={description}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="pb-16">
    <!-- Full-width cover image -->
    <div class="cover-wrap">
      <img src={coverImage} alt={title} class="cover-img" loading="eager" />
      <div class="cover-fade"></div>
      <!-- Type badge overlaid on image -->
      <div class="cover-badge-wrap">
        <span class={`type-badge type-${galleryType}`}>{typeLabel[galleryType]}</span>
        <span class="lang-pill">{lang === "en" ? "🇬🇧 EN" : "🇻🇳 VI"}</span>
      </div>
    </div>

    <!-- Content panel -->
    <div class="app-layout">
      <div class={`content-panel panel-${galleryType}`}>

        <!-- Header -->
        <header class="entry-header">
          <Datetime {pubDatetime} size="sm" class="opacity-50" />
          <h1 class="entry-title">{title}</h1>
          {description && <p class="entry-desc">{description}</p>}
          {tags.length > 0 && (
            <div class="entry-tags">
              {tags.map(t => <a href={`/tags/${t}/`} class="tag">#{t}</a>)}
            </div>
          )}
        </header>

        <!-- Audio player -->
        {audioUrl && (
          <div class="audio-bar">
            <span class="audio-label">🎵 Audio</span>
            <audio controls src={audioUrl} class="audio-player">
              Your browser does not support audio.
            </audio>
          </div>
        )}

        <!-- Content body — type-specific rendering -->
        {galleryType === "quote" ? (
          <div class="quote-body">
            <blockquote class="blockquote">
              <Content />
            </blockquote>
            {source && <p class="source-attr">— {source}</p>}
          </div>
        ) : (
          <div class:list={["prose-body", galleryType === "poem" && "poem-body", galleryType === "poem" && isLucBat && "luc-bat-body"]}>
            <Content />
          </div>
        )}

        <!-- Back link -->
        <div class="entry-back">
          <a href="/galleries" class="back-link">← Back to Galleries</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  /* ── Cover image ── */
  .cover-wrap {
    position: relative;
    width: 100%;
    height: clamp(260px, 45vh, 520px);
    overflow: hidden;
    margin-bottom: 0;
  }
  .cover-img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }
  /* Fade bottom of cover into background */
  .cover-fade {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      color-mix(in srgb, var(--background) 70%, transparent) 80%,
      var(--background) 100%
    );
  }
  /* Badges over image */
  .cover-badge-wrap {
    position: absolute; top: 1.25rem; left: 1.5rem;
    display: flex; gap: 0.5rem; align-items: center;
  }
  .type-badge {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.2rem 0.6rem; border-radius: 999px; border: 1px solid;
    backdrop-filter: blur(8px);
  }
  .type-poem  { color: #a78bfa; border-color: #a78bfa60; background: rgba(167,139,250,0.15); }
  .type-quote { color: #fbbf24; border-color: #fbbf2460; background: rgba(251,191,36,0.15); }
  .type-photo { color: #34d399; border-color: #34d39960; background: rgba(52,211,153,0.15); }
  .type-fun   { color: #f472b6; border-color: #f472b660; background: rgba(244,114,182,0.15); }
  .lang-pill {
    font-size: 0.65rem; font-weight: 600; padding: 0.1rem 0.4rem;
    border-radius: 999px; border: 1px solid rgba(255,255,255,0.2);
    background: rgba(0,0,0,0.3); color: white; backdrop-filter: blur(8px);
  }

  /* ── Content panel ── */
  .content-panel {
    margin-top: -3rem;
    position: relative; z-index: 1;
    max-width: 720px; margin-left: auto; margin-right: auto;
    border-radius: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--border) 20%, transparent);
    background: color-mix(in srgb, var(--foreground) 2%, var(--background));
    overflow: hidden;
    margin-bottom: 2rem;
  }

  /* ── Header ── */
  .entry-header {
    padding: 2rem 2.5rem 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 15%, transparent);
  }
  .entry-title {
    font-size: 1.9rem; font-weight: 700; line-height: 1.3; margin: 0.5rem 0;
    background: linear-gradient(135deg, var(--foreground), var(--accent) 80%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .entry-desc { font-size: 0.9rem; opacity: 0.6; font-style: italic; margin-bottom: 0.5rem; }
  .entry-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .tag { font-size: 0.72rem; opacity: 0.5; text-decoration: none; color: var(--foreground); transition: opacity 0.2s; }
  .tag:hover { opacity: 1; color: var(--accent); }

  /* ── Audio bar ── */
  .audio-bar {
    padding: 0.85rem 2.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 12%, transparent);
    display: flex; align-items: center; gap: 1rem;
  }
  .audio-label { font-size: 0.8rem; font-weight: 600; opacity: 0.6; white-space: nowrap; }
  .audio-player { flex: 1; height: 36px; opacity: 0.8; }

  /* ── Poem body ── */
  .prose-body {
    padding: 2rem 2.5rem 1.5rem;
    font-size: 1.05rem; line-height: 2;
    color: var(--foreground);
  }
  .poem-body {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.1rem; line-height: 2.3;
    white-space: pre-line;
  }
  .luc-bat-body { text-align: center; letter-spacing: 0.01em; }
  .prose-body :global(p) { margin: 0 0 1.2rem; }
  .prose-body :global(p:last-child) { margin-bottom: 0; }

  /* ── Quote body ── */
  .quote-body {
    padding: 2rem 2.5rem 1.5rem;
  }
  .blockquote {
    position: relative;
    margin: 0;
    padding: 1.5rem 2rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--accent) 4%, transparent);
    border-left: 3px solid var(--accent);
    font-size: 1.2rem; line-height: 1.8;
    font-style: italic; color: var(--foreground);
  }
  .blockquote::before {
    content: "\201C";
    position: absolute; top: -0.5rem; left: 1.5rem;
    font-size: 4rem; line-height: 1; opacity: 0.15;
    font-family: Georgia, serif;
  }
  .blockquote :global(p) { margin: 0 0 0.75rem; }
  .blockquote :global(p:last-child) { margin: 0; }
  .source-attr {
    margin-top: 1rem; text-align: right;
    font-size: 0.85rem; opacity: 0.55; font-style: italic;
  }

  /* ── Photo body (caption style) ── */
  .panel-photo .prose-body {
    font-size: 0.95rem; line-height: 1.75; opacity: 0.85;
  }

  /* ── Back link ── */
  .entry-back {
    padding: 1rem 2.5rem 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 12%, transparent);
  }
  .back-link {
    font-size: 0.85rem; color: var(--accent); opacity: 0.7;
    text-decoration: none; transition: opacity 0.2s;
  }
  .back-link:hover { opacity: 1; }
</style>
