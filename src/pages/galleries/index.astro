---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

if (!SITE.showGalleries) {
  return Astro.redirect("/404");
}

function getSlug(id: string) {
  return id.replace(/\/index\.(md|mdx)$/, "").replace(/\.(md|mdx)$/, "");
}

function getBodyPreview(body: string | undefined, maxLines = 3): string {
  if (!body) return '';
  return body
    .trim()
    .split('\n')
    .map(l => l.replace(/^#{1,6}\s+/, '').replace(/\*\*?(.+?)\*\*?/g, '$1').trim())
    .filter(l => l.length > 0 && !l.startsWith('!') && !l.startsWith('[') && !l.startsWith('>'))
    .slice(0, maxLines)
    .join('\n');
}

const raw = await getCollection("galleries", ({ data }) => !data.draft);
const galleries = raw
  .sort((a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime())
  .map(g => ({ ...g, slug: getSlug(g.id), bodyPreview: getBodyPreview(g.body, 3) }));

const typeLabel: Record<string, string> = {
  poem: "Thơ", quote: "Quote", photo: "Photo", fun: "Fun",
};
const typeIcon: Record<string, string> = {
  poem: "✦", quote: "❝", photo: "◈", fun: "✿",
};
---

<Layout title={`Galleries | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12 mt-8">
    <!-- Filter bar -->
    <div class="filter-bar" id="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Type</span>
        <button class="filter-btn active" data-type="all">All</button>
        <button class="filter-btn" data-type="poem">✦ Thơ</button>
        <button class="filter-btn" data-type="quote">❝ Quote</button>
        <button class="filter-btn" data-type="photo">◈ Photo</button>
        <button class="filter-btn" data-type="fun">✿ Fun</button>
      </div>
    </div>

    <!-- Masonry grid -->
    {galleries.length === 0 ? (
      <p class="mt-12 text-center text-foreground/50 italic">No galleries published yet.</p>
    ) : (
      <div class="masonry-grid" id="masonry-grid">
        {galleries.map(g => (
          <div class="masonry-item" data-type={g.data.galleryType}>
            <a href={`/galleries/${g.slug}/`} class="gallery-card">
              <img src={g.data.coverImage} alt={g.data.title} class="card-bg-img" loading="lazy" />
              <div class="card-overlay">
                <div class="card-top">
                  <span class={`type-badge type-${g.data.galleryType}`}>
                    {typeIcon[g.data.galleryType]} {typeLabel[g.data.galleryType]}
                  </span>
                  <span class="lang-dot">{g.data.lang === "en" ? "🇬🇧" : "🇻🇳"}</span>
                </div>
                <div class="card-bottom">
                  <time class="card-date">
                    {g.data.pubDatetime.toLocaleDateString('vi-VN', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                  <h2 class="card-title">{g.data.title}</h2>
                  {g.bodyPreview && <p class="card-preview">{g.bodyPreview}</p>}
                  {g.data.source && <p class="card-source">— {g.data.source}</p>}
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
      <p class="empty-filter-msg" id="empty-filter-msg" style="display:none">
        No entries match the current filter.
      </p>
    )}
  </main>
  <Footer />
</Layout>

<script>
  function initFilters() {
    const params = new URLSearchParams(window.location.search);
    let activeType = params.get("type") || "all";

    const items = document.querySelectorAll<HTMLElement>(".masonry-item");
    const emptyMsg = document.getElementById("empty-filter-msg");
    const typeBtns = document.querySelectorAll<HTMLButtonElement>("#filter-bar [data-type]");

    function applyFilter() {
      let visible = 0;
      items.forEach(item => {
        const ok = activeType === "all" || item.dataset.type === activeType;
        item.style.display = ok ? "" : "none";
        if (ok) visible++;
      });
      if (emptyMsg) emptyMsg.style.display = visible === 0 ? "" : "none";
      const p = new URLSearchParams();
      if (activeType !== "all") p.set("type", activeType);
      window.history.replaceState({}, "", p.toString() ? `?${p}` : window.location.pathname);
    }

    function bindGroup(
      btns: NodeListOf<HTMLButtonElement>,
      attr: string,
      getter: () => string,
      setter: (v: string) => void
    ) {
      btns.forEach(btn => {
        const val = (btn.dataset as any)[attr];
        btn.classList.toggle("active", val === getter());
        btn.addEventListener("click", () => {
          setter(val);
          btns.forEach(b => b.classList.toggle("active", (b.dataset as any)[attr] === val));
          applyFilter();
        });
      });
    }

    bindGroup(typeBtns, "type", () => activeType, v => (activeType = v));
    applyFilter();
  }

  document.addEventListener("astro:page-load", initFilters);
</script>

<style>
  /* Filter bar */
  .filter-bar { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; align-items: center; }
  .filter-group { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  @media (max-width: 639px) {
    .filter-bar { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; padding-bottom: 4px; }
    .filter-bar::-webkit-scrollbar { display: none; }
    .filter-group { flex-shrink: 0; flex-wrap: nowrap; }
  }
  .filter-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; opacity: 0.4; text-transform: uppercase; margin-right: 0.2rem; }
  .filter-btn {
    padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.78rem;
    border: 1px solid color-mix(in srgb, var(--border) 30%, transparent);
    background: transparent; color: var(--foreground); opacity: 0.6; cursor: pointer; transition: all 0.2s ease;
  }
  .filter-btn:hover { opacity: 1; border-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  .filter-btn.active {
    opacity: 1; color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  /* Masonry */
  .masonry-grid { columns: 1; column-gap: 1.25rem; }
  @media (min-width: 540px) { .masonry-grid { columns: 2; } }
  @media (min-width: 1024px) { .masonry-grid { columns: 3; } }
  .masonry-item { break-inside: avoid; margin-bottom: 1.25rem; }

  /* Gallery card — full bleed */
  .gallery-card {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: 1.25rem;
    overflow: hidden;
    height: 320px;
    border: 1px solid color-mix(in srgb, var(--border) 20%, transparent);
    background: var(--background);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  @media (min-width: 1024px) { .gallery-card { height: 360px; } }
  .gallery-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    box-shadow: 0 12px 40px -8px color-mix(in srgb, var(--accent) 18%, transparent);
  }

  /* Background image */
  .card-bg-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .gallery-card:hover .card-bg-img { transform: scale(1.05); }

  /* Overlay structure */
  .card-overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: space-between;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.18) 0%,
      transparent 25%,
      rgba(0,0,0,0.08) 44%,
      rgba(0,0,0,0.48) 62%,
      rgba(0,0,0,0.84) 100%
    );
  }
  /* Blur fading in over bottom half — smooth ramp via partial-opacity mask */
  .card-overlay::before {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 65%;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.45) 32%, black 60%);
    mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.45) 32%, black 60%);
    pointer-events: none;
  }

  /* Top badges */
  .card-top {
    position: relative; z-index: 2;
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.85rem 1rem;
  }

  /* Bottom content */
  .card-bottom {
    position: relative; z-index: 2;
    padding: 1rem 1.2rem 1.2rem;
  }
  .card-date {
    display: block;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.3rem;
  }
  .card-title {
    font-size: 1rem; font-weight: 600;
    color: rgba(255,255,255,0.95);
    line-height: 1.4; margin: 0 0 0.4rem;
    transition: color 0.2s;
  }
  .gallery-card:hover .card-title { color: #fff; }
  .card-preview {
    font-size: 0.79rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.65;
    white-space: pre-line;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .card-source {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    font-style: italic; margin-top: 0.4rem;
  }

  /* Type badges — dark base ensures legibility on any image */
  .type-badge {
    font-size: 0.62rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.2rem 0.6rem; border-radius: 999px; border: 1px solid;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    background: rgba(0,0,0,0.48);
    box-shadow: 0 1px 6px rgba(0,0,0,0.35);
  }
  .type-poem   { color: #b5e0fdff; border-color: #8bdafa90; }
  .type-quote  { color: #fde68a; border-color: #fbbf2490; }
  .type-photo  { color: #6ee7b7; border-color: #34d39990; }
  .type-fun    { color: #fbcfe8; border-color: #f472b690; }
  .lang-dot { font-size: 0.8rem; }

  .empty-filter-msg { text-align: center; padding: 3rem; opacity: 0.5; font-style: italic; }
</style>
