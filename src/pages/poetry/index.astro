---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Datetime from "@/components/Datetime.astro";
import { SITE } from "@/config";

const allPoems = await getCollection("poetry", ({ data }) => !data.draft);
const sorted = allPoems.sort(
  (a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime()
);

const typeLabel: Record<string, string> = {
  "luc-bat": "Lục Bát",
  "tu-do": "Tự Do",
  "free-verse": "Free Verse",
};
---

<Layout title={`Poetry | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12">
    <!-- Hero -->
    <div class="section-hero">
      <div class="aurora-orb aurora-orb-1"></div>
      <div class="aurora-orb aurora-orb-2"></div>
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          <span class="glow-text">Poetry</span>
        </h1>
        <p class="mt-3 max-w-lg text-foreground/70 italic">
          Thơ — lục bát, tự do, và những suy nghĩ không vừa vào code comment.
        </p>
        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="hero-badge">{sorted.length} bài</span>
        </div>
      </div>
    </div>

    <!-- Lang Filter -->
    <div class="filter-bar" id="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Lang</span>
        <button class="filter-btn active" data-lang="all">All</button>
        <button class="filter-btn" data-lang="vi">🇻🇳 Tiếng Việt</button>
        <button class="filter-btn" data-lang="en">🇬🇧 English</button>
      </div>
      <div class="filter-group">
        <span class="filter-label">Type</span>
        <button class="filter-btn active" data-type="all">All</button>
        <button class="filter-btn" data-type="luc-bat">Lục Bát</button>
        <button class="filter-btn" data-type="tu-do">Tự Do</button>
        <button class="filter-btn" data-type="free-verse">Free Verse</button>
      </div>
    </div>

    <!-- Poem list -->
    <ul class="poem-list" id="poem-list">
      {sorted.map(poem => (
        <li class="poem-card" data-lang={poem.data.lang} data-type={poem.data.poemType}>
          <a href={`/poetry/${poem.id}/`} class="poem-link">
            <div class="poem-meta">
              <span class="poem-type-badge">{typeLabel[poem.data.poemType]}</span>
              <Datetime pubDatetime={poem.data.pubDatetime} size="sm" class="opacity-60" />
              <span class="lang-pill">{poem.data.lang === "en" ? "🇬🇧 EN" : "🇻🇳 VI"}</span>
            </div>
            <h2 class="poem-title">{poem.data.title}</h2>
            <p class="poem-desc">{poem.data.description}</p>
            {poem.data.tags.length > 0 && (
              <div class="poem-tags">
                {poem.data.tags.map(t => <span class="tag">#{t}</span>)}
              </div>
            )}
          </a>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</Layout>

<script>
  function initFilters() {
    const params = new URLSearchParams(window.location.search);
    let activeLang = params.get("lang") || "all";
    let activeType = params.get("type") || "all";

    const items = document.querySelectorAll<HTMLElement>(".poem-card");
    const langBtns = document.querySelectorAll<HTMLButtonElement>("[data-lang]");
    const typeBtns = document.querySelectorAll<HTMLButtonElement>("[data-type]");

    function applyFilter() {
      items.forEach(item => {
        const matchLang = activeLang === "all" || item.dataset.lang === activeLang;
        const matchType = activeType === "all" || item.dataset.type === activeType;
        item.style.display = matchLang && matchType ? "" : "none";
      });
      // Update URL
      const p = new URLSearchParams();
      if (activeLang !== "all") p.set("lang", activeLang);
      if (activeType !== "all") p.set("type", activeType);
      const newUrl = p.toString() ? `?${p}` : window.location.pathname;
      window.history.replaceState({}, "", newUrl);
    }

    function setActive(btns: NodeListOf<HTMLButtonElement>, value: string) {
      btns.forEach(b => b.classList.toggle("active", b.dataset.lang === value || b.dataset.type === value));
    }

    langBtns.forEach(btn => {
      if (btn.dataset.lang) {
        btn.classList.toggle("active", btn.dataset.lang === activeLang);
        btn.addEventListener("click", () => {
          activeLang = btn.dataset.lang!;
          setActive(langBtns, activeLang);
          applyFilter();
        });
      }
    });

    typeBtns.forEach(btn => {
      if (btn.dataset.type) {
        btn.classList.toggle("active", btn.dataset.type === activeType);
        btn.addEventListener("click", () => {
          activeType = btn.dataset.type!;
          setActive(typeBtns, activeType);
          applyFilter();
        });
      }
    });

    applyFilter();
  }

  document.addEventListener("astro:page-load", initFilters);
</script>

<style>
  .section-hero {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    padding: 2.5rem 2rem;
    margin-bottom: 2rem;
    background: color-mix(in srgb, var(--color-foreground) 3%, var(--color-background));
    border: 1px solid color-mix(in srgb, var(--color-accent) 12%, transparent);
  }
  .aurora-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }
  .aurora-orb-1 {
    width: 280px; height: 280px; top: -40%; left: -10%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 20%, transparent), transparent 70%);
    animation: orb1 8s ease-in-out infinite alternate;
  }
  .aurora-orb-2 {
    width: 200px; height: 200px; bottom: -30%; right: -5%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-border) 18%, transparent), transparent 70%);
    animation: orb2 10s ease-in-out infinite alternate;
  }
  @keyframes orb1 { 0% { transform: translate(0,0); } 100% { transform: translate(40px, 25px); } }
  @keyframes orb2 { 0% { transform: translate(0,0); } 100% { transform: translate(-30px, -20px); } }

  .glow-text {
    background: linear-gradient(135deg, var(--color-foreground), var(--color-accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hero-badge {
    display: inline-flex; align-items: center; padding: 0.3rem 0.85rem;
    border-radius: 999px; font-size: 0.8rem; font-weight: 600;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  /* Filter bar */
  .filter-bar {
    display: flex; flex-wrap: wrap; gap: 1rem;
    margin-bottom: 2rem; align-items: center;
  }
  .filter-group {
    display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;
  }
  .filter-label {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em;
    color: var(--foreground); opacity: 0.4; text-transform: uppercase;
    margin-right: 0.2rem;
  }
  .filter-btn {
    padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.78rem;
    border: 1px solid color-mix(in srgb, var(--border) 30%, transparent);
    background: transparent; color: var(--foreground); opacity: 0.6;
    cursor: pointer; transition: all 0.2s ease;
  }
  .filter-btn:hover { opacity: 1; border-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  .filter-btn.active {
    opacity: 1; color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  /* Poem list */
  .poem-list {
    display: flex; flex-direction: column; gap: 1rem; list-style: none; padding: 0; margin: 0;
  }
  .poem-card {
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--border) 20%, transparent);
    transition: all 0.25s ease;
  }
  .poem-card:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    background: color-mix(in srgb, var(--accent) 3%, transparent);
    transform: translateY(-1px);
  }
  .poem-link {
    display: block; padding: 1.25rem 1.5rem; text-decoration: none;
  }
  .poem-meta {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .poem-type-badge {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    padding: 0.1rem 0.5rem; border-radius: 999px;
  }
  .lang-pill {
    font-size: 0.65rem; font-weight: 600;
    padding: 0.1rem 0.4rem; border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    color: var(--foreground); opacity: 0.6;
  }
  .poem-title {
    font-size: 1.15rem; font-weight: 600;
    color: var(--foreground); margin-bottom: 0.35rem;
    transition: color 0.2s ease;
  }
  .poem-card:hover .poem-title { color: var(--accent); }
  .poem-desc { font-size: 0.875rem; color: var(--foreground); opacity: 0.6; line-height: 1.6; }
  .poem-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.6rem; }
  .tag { font-size: 0.7rem; opacity: 0.5; }
</style>
