---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Datetime from "@/components/Datetime.astro";
import { SITE } from "@/config";

export async function getStaticPaths() {
  const poems = await getCollection("poetry", ({ data }) => !data.draft);
  return poems.map(poem => ({
    params: { slug: poem.id },
    props: { poem },
  }));
}

const { poem } = Astro.props;
const { title, description, pubDatetime, lang, poemType, audioUrl, tags } = poem.data;
const { Content } = await render(poem);

const typeLabel: Record<string, string> = {
  "luc-bat": "Lục Bát",
  "tu-do": "Thơ Tự Do",
  "free-verse": "Free Verse",
};
---

<Layout title={`${title} | Poetry | ${SITE.title}`} description={description}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12">
    <div class="poem-panel">
      <!-- Aurora glow -->
      <div class="poem-aurora" aria-hidden="true"></div>

      <!-- Header -->
      <header class="poem-header">
        <div class="poem-meta">
          <span class="type-badge">{typeLabel[poemType]}</span>
          <Datetime {pubDatetime} size="sm" class="opacity-60" />
          <span class="lang-pill">{lang === "en" ? "🇬🇧 EN" : "🇻🇳 VI"}</span>
        </div>
        <h1 class="poem-title">{title}</h1>
        {description && <p class="poem-desc">{description}</p>}
        {tags.length > 0 && (
          <div class="poem-tags">
            {tags.map(t => (
              <a href={`/tags/${t}/`} class="tag">#{t}</a>
            ))}
          </div>
        )}
      </header>

      <!-- Audio player (if present) -->
      {audioUrl && (
        <div class="poem-audio">
          <span class="audio-label">🎵 Audio</span>
          <audio controls src={audioUrl} class="audio-player">
            Your browser does not support audio.
          </audio>
        </div>
      )}

      <!-- Poem content -->
      <div class:list={["poem-content", poemType === "luc-bat" && "luc-bat"]}>
        <Content />
      </div>

      <!-- Back link -->
      <div class="poem-back">
        <a href="/poetry" class="back-link">← Back to Poetry</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .poem-panel {
    position: relative;
    max-width: 680px;
    margin: 2rem auto;
    border-radius: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--accent) 15%, transparent);
    background: color-mix(in srgb, var(--foreground) 2%, var(--background));
    overflow: hidden;
    backdrop-filter: blur(12px);
  }
  .poem-aurora {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 0%, color-mix(in srgb, var(--accent) 8%, transparent), transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 100%, color-mix(in srgb, var(--accent) 5%, transparent), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .poem-header {
    position: relative; z-index: 1;
    padding: 2.5rem 2.5rem 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 20%, transparent);
    text-align: center;
  }
  .poem-meta {
    display: flex; justify-content: center; align-items: center;
    gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1rem;
  }
  .type-badge {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    padding: 0.15rem 0.55rem; border-radius: 999px;
  }
  .lang-pill {
    font-size: 0.65rem; font-weight: 600;
    padding: 0.1rem 0.4rem; border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    opacity: 0.6;
  }
  .poem-title {
    font-size: 2rem; font-weight: 700;
    background: linear-gradient(135deg, var(--foreground), var(--accent) 80%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    margin-bottom: 0.5rem; line-height: 1.3;
  }
  .poem-desc { font-size: 0.9rem; opacity: 0.6; font-style: italic; }
  .poem-tags {
    display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem;
  }
  .tag {
    font-size: 0.72rem; opacity: 0.5; transition: opacity 0.2s;
    text-decoration: none; color: var(--foreground);
  }
  .tag:hover { opacity: 1; color: var(--accent); }

  /* Audio */
  .poem-audio {
    position: relative; z-index: 1;
    padding: 1rem 2.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 15%, transparent);
    display: flex; align-items: center; gap: 1rem;
  }
  .audio-label { font-size: 0.8rem; font-weight: 600; opacity: 0.6; white-space: nowrap; }
  .audio-player { flex: 1; height: 36px; opacity: 0.8; }

  /* Poem body */
  .poem-content {
    position: relative; z-index: 1;
    padding: 2rem 2.5rem 1.5rem;
    font-size: 1.05rem;
    line-height: 2.2;
    color: var(--foreground);
    white-space: pre-line;
  }
  /* Lục bát: center align */
  .poem-content.luc-bat {
    text-align: center;
    font-size: 1.1rem;
    line-height: 2.4;
    letter-spacing: 0.01em;
  }
  /* Prose reset for poem content */
  .poem-content :global(p) {
    margin: 0 0 1.5rem;
    white-space: pre-line;
  }
  .poem-content :global(p:last-child) { margin-bottom: 0; }

  .poem-back {
    position: relative; z-index: 1;
    padding: 1rem 2.5rem 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 15%, transparent);
  }
  .back-link {
    font-size: 0.85rem; color: var(--accent); opacity: 0.7;
    text-decoration: none; transition: opacity 0.2s;
  }
  .back-link:hover { opacity: 1; }
</style>
